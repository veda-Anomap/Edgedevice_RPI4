CXX = g++
CXXFLAGS = -O3 -Wall -std=c++17
LDFLAGS = `pkg-config --libs opencv4` -ltensorflow-lite -lpthread -ldl

# Paths
SRC_DIR = src
TEST_DIR = tester
OBJ_DIR = obj

# Sources
SOURCES = $(TEST_DIR)/tester_main.cpp \
          $(TEST_DIR)/TesterApp.cpp \
          $(TEST_DIR)/TesterModes.cpp \
          $(SRC_DIR)/imageprocessing/AdvancedEnhancers.cpp \
          $(SRC_DIR)/imageprocessing/ImagePreprocessor.cpp \
          $(SRC_DIR)/imageprocessing/LowLightEnhancer.cpp \
          $(SRC_DIR)/ai/PoseEstimator.cpp \
          $(SRC_DIR)/ai/FallDetector.cpp \
          $(SRC_DIR)/rendering/FrameRenderer.cpp

OBJS = $(patsubst %.cpp, $(OBJ_DIR)/%.o, $(not_Visualized_path_conversion))
# Simplified for now (just listing objects manually to avoid path issues with patsubst)
OBJ_FILES = $(OBJ_DIR)/tester_main.o \
            $(OBJ_DIR)/TesterApp.o \
            $(OBJ_DIR)/TesterModes.o \
            $(OBJ_DIR)/AdvancedEnhancers.o \
            $(OBJ_DIR)/ImagePreprocessor.o \
            $(OBJ_DIR)/LowLightEnhancer.o \
            $(OBJ_DIR)/PoseEstimator.o \
            $(OBJ_DIR)/FallDetector.o \
            $(OBJ_DIR)/FrameRenderer.o

TARGET = subcam_tester

all: $(TARGET)

$(TARGET): $(OBJ_FILES)
	$(CXX) $(OBJ_FILES) -o $(TARGET) $(LDFLAGS)

$(OBJ_DIR)/%.o: $(TEST_DIR)/%.cpp
	@mkdir -p $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(OBJ_DIR)/%.o: $(SRC_DIR)/imageprocessing/%.cpp
	@mkdir -p $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(OBJ_DIR)/%.o: $(SRC_DIR)/ai/%.cpp
	@mkdir -p $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(OBJ_DIR)/%.o: $(SRC_DIR)/rendering/%.cpp
	@mkdir -p $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -rf $(OBJ_DIR) $(TARGET)
